alue\":\"OUTSTANDING_AMOUNT\"},{\"Description\":\"VARCHAR\",\"Label\":\"INTEREST_RATE\",\"Value\":\"INTEREST_RATE\"},{\"Description\":\"VARCHAR\",\"Label\":\"TERM_MONTHS\",\"Value\":\"TERM_MONTHS\"},{\"Description\":\"VARCHAR\",\"Label\":\"PAYMENT_FREQUENCY\",\"Value\":\"PAYMENT_FREQUENCY\"},{\"Description\":\"VARCHAR\",\"Label\":\"CURRENCY\",\"Value\":\"CURRENCY\"},{\"Description\":\"VARCHAR\",\"Label\":\"BRANCH_CODE\",\"Value\":\"BRANCH_CODE\"},{\"Description\":\"VARCHAR\",\"Label\":\"BRANCH_NAME\",\"Value\":\"BRANCH_NAME\"},{\"Description\":\"VARCHAR\",\"Label\":\"VERSION_DATE\",\"Value\":\"VERSION_DATE\"},{\"Description\":\"VARCHAR\",\"Label\":\"ETL_UPDATE_DATE\",\"Value\":\"ETL_UPDATE_DATE\"}],\"TempDir\":\"s3://gsb-ai-data-driven-data-nonprod-201064226169/glue/temp/\",\"Upsert\":false},\"Inputs\":[\"node-1\"],\"Name\":\"Redshift Target - gsbds.case03_fixed_length_table\"}}}"
