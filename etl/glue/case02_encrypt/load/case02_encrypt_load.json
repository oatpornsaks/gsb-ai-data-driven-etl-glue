  "codeGenConfigurationNodes": "{\"node-1\":{\"S3CsvSource\":{\"AdditionalOptions\":{\"EnableSamplePath\":false,\"SamplePath\":\"\"},\"Escaper\":\"\\\\\",\"Exclusions\":[],\"Name\":\"S3 CSV Source - case02_encrypt staging\",\"OptimizePerformance\":false,\"OutputSchemas\":[{\"Columns\":[]}],\"Paths\":[\"s3://gsb-ai-data-driven-data-nonprod-201064226169/staging/case02_encrypt/load/\"],\"QuoteChar\":\"quote\",\"Recurse\":true,\"Separator\":\"comma\",\"WithHeader\":true}},\"node-2\":{\"AmazonRedshiftTarget\":{\"Data\":{\"AccessType\":\"connection\",\"Action\":\"append\",\"AdvancedOptions\":[],\"Connection\":{\"Label\":\"gsb-ai-data-driven-redshift-connection-poc\",\"Value\":\"gsb-ai-data-driven-redshift-connection-poc\"},\"MergeAction\":\"simple\",\"MergeWhenMatched\":\"update\",\"MergeWhenNotMatched\":\"insert\",\"Schema\":{\"Label\":\"gsbds\",\"Value\":\"gsbds\"},\"SelectedColumns\":[],\"SourceType\":\"table\",\"StagingTable\":\"gsbds.case02_encrypt_table_temp\",\"Table\":{\"Label\":\"case02_encrypt_table\",\"Value\":\"case02_encrypt_table\"},\"TableSchema\":[{\"Description\":\"VARCHAR\",\"Label\":\"CARD_NUMBER\",\"Value\":\"CARD_NUMBER\"},{\"Description\":\"VARCHAR\",\"Label\":\"CARD_HOLDER_NAME\",\"Value\":\"CARD_HOLDER_NAME\"},{\"Description\":\"VARCHAR\",\"Label\":\"EXPIRY_DATE\",\"Value\":\"EXPIRY_DATE\"},{\"Description\":\"VARCHAR\",\"Label\":\"CARD_TYPE\",\"Value\":\"CARD_TYPE\"},{\"Description\":\"VARCHAR\",\"Label\":\"CREDIT_LIMIT\",\"Value\":\"CREDIT_LIMIT\"},{\"Description\":\"VARCHAR\",\"Label\":\"OUTSTANDING_BALANCE\",\"Value\":\"OUTSTANDING_BALANCE\"},{\"Description\":\"VARCHAR\",\"Label\":\"VERSION_DATE\",\"Value\":\"VERSION_DATE\"},{\"Description\":\"VARCHAR\",\"Label\":\"ETL_UPDATE_DATE\",\"Value\":\"ETL_UPDATE_DATE\"}],\"TempDir\":\"s3://gsb-ai-data-driven-data-nonprod-201064226169/glue/temp/\",\"Upsert\":false},\"Inputs\":[\"node-1\"],\"Name\":\"Redshift Target - gsbds.case02_encrypt_table\"}}}"
